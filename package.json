{
  "name": "morsewalker-ru",
  "version": "0.2.0",
  "description": "Веб-тренажёр CW: пайлапы, контестные режимы (RDA, WPX, CWT, SST, POTA), русская локализация. Форк Morse Walker (W6NYC).",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "cw",
    "morse-code",
    "ham-radio",
    "amateur-radio",
    "contest",
    "pileup-trainer",
    "rda",
    "wpx"
  ],
  "homepage": "https://morse.r9o.ru",
  "license": "MIT",
  "author": "R9OGL <admin@r9o.ru>",
  "contributors": [
    "W6NYC (Henry Prince) — оригинальный Morse Walker"
  ],
  "scripts": {
    "test": "node --test",
    "start": "webpack serve --open --config webpack.config.dev.js",
    "build": "webpack --config webpack.config.prod.js && jsdoc -c jsdoc.json",
    "format": "prettier --write \"src/**/*.{js,css,html}\"",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.0",
    "husky": "^9.1.7",
    "jsdoc": "^4.0.4",
    "mini-css-extract-plugin": "^2.9.2",
    "prettier": "^3.5.1",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.3.10",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.1.0",
    "webpack-merge": "^5.10.0"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.7.1",
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.3",
    "bootswatch": "^5.3.3"
  }
}
